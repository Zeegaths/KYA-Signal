# =====================================================================
# KYA Signal — Backend Environment Variables
# Copy this to .env and fill in your values
# =====================================================================

# ── DATABASE ─────────────────────────────────────────────────────────
# Local:  postgresql://postgres:password@localhost:5432/kya_signal
# Neon:   postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/kya_signal?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/kya_signal

# ── REDIS ─────────────────────────────────────────────────────────────
# Local:   localhost
# Upstash: your-upstash-endpoint.upstash.io
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── STACKS / ORACLE ───────────────────────────────────────────────────
# The wallet that signs score submissions to the Clarity contracts
ORACLE_PRIVATE_KEY=your_stacks_private_key_hex
ORACLE_STACKS_ADDRESS=SP...

# Deployed contract address (your Stacks address that deployed the contracts)
KYA_CONTRACT_ADDRESS=SP...

# testnet | mainnet
STACKS_NETWORK=testnet

# ── CHAIN RPC ENDPOINTS ───────────────────────────────────────────────
# Solana — Helius: https://dev.helius.xyz  |  QuickNode: https://quicknode.com
SOLANA_RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Ethereum — Alchemy: https://dashboard.alchemy.com
ETH_RPC_ENDPOINT=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── EMAIL (Zepto Mail) ────────────────────────────────────────────────
# https://www.zeptomail.com → API Keys
ZEPTO_API_KEY=your_zepto_api_key

# ── SERVER ────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000

